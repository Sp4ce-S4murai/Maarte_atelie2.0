---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CartDrawer from '../../components/CartDrawer.tsx';
import AddToCartButton from '../../components/AddToCartButton.tsx';
import { products, categoryLabels, getProductBySlug } from '../../data/products';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
};

const { product } = Astro.props;

const specLabels: Record<string, string> = {
  material: '📦 Material',
  gramatura: '📏 Gramatura',
  impressao: '🖨️ Tipo de Impressão',
  tamanho: '📐 Tamanho',
  acabamento: '✨ Acabamento',
  quantidade: '📊 Quantidade',
  personalizacao: '🎨 Personalização',
  prazoProducao: '⏱️ Prazo de Produção',
};

const categoryEmoji: Record<string, string> = {
  topper: '🎂',
  lembrancinha: '🎁',
  forminha: '🧁',
};

// Related products (same category, excluding current)
const relatedProducts = products
  .filter((p) => p.category === product.category && p.id !== product.id)
  .slice(0, 2);
---

<Layout
  title={`${product.name} — MaarteAtelie`}
  description={product.description}
>
  <Header />

  <main class="bg-oat-milk">
    <!-- Breadcrumb -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm" aria-label="Breadcrumb">
        <a href="/" class="font-semibold hover:text-blush transition-colors">Início</a>
        <span class="text-red-wine/40">›</span>
        <a href="/#produtos" class="font-semibold hover:text-blush transition-colors">Produtos</a>
        <span class="text-red-wine/40">›</span>
        <a href={`/#produtos`} class="font-semibold hover:text-blush transition-colors">{categoryLabels[product.category]}</a>
        <span class="text-red-wine/40">›</span>
        <span class="text-red-wine/60">{product.name}</span>
      </nav>
    </div>

    <!-- Product section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Image -->
        <div class="relative">
          <div class="bg-rose-quartz border-2 border-red-wine shadow-brutal-lg overflow-hidden sticky top-24">
            <div class="aspect-square">
              <img
                src={product.image}
                alt={product.name}
                class="w-full h-full object-cover"
              />
            </div>
            <!-- Category badge -->
            <span class="absolute top-4 left-4 bg-oat-milk border-2 border-red-wine px-3 py-1 text-xs font-bold uppercase tracking-wider shadow-brutal-sm">
              {categoryEmoji[product.category]} {categoryLabels[product.category]}
            </span>
          </div>
        </div>

        <!-- Info -->
        <div class="flex flex-col">
          <!-- Header -->
          <div class="mb-6">
            <div class="flex flex-wrap gap-2 mb-3">
              {product.tags.map((tag: string) => (
                <span class="bg-blush/40 border border-red-wine/30 px-2 py-0.5 text-xs font-semibold uppercase tracking-wider">
                  {tag}
                </span>
              ))}
            </div>
            <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-red-wine leading-tight mb-3">
              {product.name}
            </h1>
            <p class="text-base sm:text-lg text-red-wine/70 leading-relaxed">
              {product.longDescription}
            </p>
          </div>

          <!-- Price -->
          <div class="bg-rose-quartz border-2 border-red-wine shadow-brutal p-5 mb-6">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-sm font-semibold text-red-wine/60 uppercase tracking-wider">A partir de</span>
            </div>
            <span class="font-serif text-4xl font-bold text-red-wine">
              R$ {product.price.toFixed(2).replace('.', ',')}
            </span>
            <p class="text-xs text-red-wine/50 mt-1">
              *Valor unitário. Descontos para pedidos acima de 50 unidades.
            </p>
          </div>

          <!-- Add to Cart -->
          <div class="mb-8">
            <AddToCartButton
              client:visible
              product={{
                id: product.id,
                name: product.name,
                price: product.price,
                image: product.image,
              }}
            />
            <a
              href="https://wa.me/5554581206756"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-brutal btn-brutal-secondary w-full text-center mt-3"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Tirar dúvidas pelo WhatsApp
            </a>
          </div>

          <!-- Includes -->
          <div class="bg-oat-milk border-2 border-red-wine shadow-brutal-sm p-5 mb-6">
            <h3 class="font-serif text-lg font-bold mb-3 flex items-center gap-2">
              <span>📋</span> O que está incluso
            </h3>
            <ul class="space-y-2">
              {product.includes.map((item: string) => (
                <li class="flex items-start gap-2 text-sm">
                  <span class="text-red-wine mt-0.5 font-bold">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Specs -->
          <div class="border-2 border-red-wine shadow-brutal bg-rose-quartz">
            <h3 class="font-serif text-lg font-bold p-5 pb-3 flex items-center gap-2">
              <span>🔍</span> Especificações Técnicas
            </h3>
            <div class="divide-y divide-red-wine/20">
              {Object.entries(product.specs).map(([key, value]) => {
                if (!value) return null;
                return (
                  <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 px-5 py-3">
                    <span class="font-bold text-sm whitespace-nowrap min-w-[180px]">
                      {specLabels[key] || key}
                    </span>
                    <span class="text-sm text-red-wine/80">{value}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>

      <!-- Related products -->
      {relatedProducts.length > 0 && (
        <div class="mt-16 pt-12 border-t-2 border-red-wine/20">
          <h2 class="font-serif text-2xl sm:text-3xl font-bold mb-8 text-center">
            Você também pode gostar
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
            {relatedProducts.map((related) => (
              <a
                href={`/produto/${related.slug}`}
                class="group bg-rose-quartz border-2 border-red-wine shadow-brutal hover:shadow-brutal-lg hover:-translate-x-0.5 hover:-translate-y-0.5 transition-all duration-200 flex flex-col no-underline text-red-wine"
              >
                <div class="relative overflow-hidden border-b-2 border-red-wine aspect-square bg-blush/30">
                  <img
                    src={related.image}
                    alt={related.name}
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
                <div class="p-4">
                  <h3 class="font-serif text-lg font-bold mb-1">{related.name}</h3>
                  <span class="font-serif text-xl font-bold">
                    R$ {related.price.toFixed(2).replace('.', ',')}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </section>
  </main>

  <Footer />
  <CartDrawer client:load />
</Layout>
