---
import CartIcon from './CartIcon.tsx';
---

<header class="sticky top-0 z-50 bg-oat-milk border-b-2 border-red-wine">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <img src="/logo.png" alt="Maarte Atelie Logo" class="h-10 sm:h-12 w-auto object-contain transition-transform duration-300 group-hover:scale-105" />
      </a>

      <!-- Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/#produtos" class="text-sm font-semibold uppercase tracking-wider hover:text-blush transition-colors">
          Produtos
        </a>
        <a href="/#sobre" class="text-sm font-semibold uppercase tracking-wider hover:text-blush transition-colors">
          Sobre
        </a>
        <a href="/#contato" class="text-sm font-semibold uppercase tracking-wider hover:text-blush transition-colors">
          Contato
        </a>
      </nav>

      <!-- Cart Button -->
      <CartIcon client:load />
    </div>
  </div>
</header>
