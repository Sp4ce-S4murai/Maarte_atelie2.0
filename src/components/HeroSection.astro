---
---

<section class="relative overflow-hidden">
  <!-- Checkerboard top border -->
  <div class="checkerboard-sm h-10 sm:h-14"></div>

  <!-- Hero content -->
  <div class="bg-rose-quartz py-12 sm:py-20 px-4">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
      <!-- Text -->
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-block bg-oat-milk border-2 border-red-wine px-3 py-1 shadow-brutal-sm mb-6 text-xs font-bold uppercase tracking-widest">
          ✦ Papelaria Criativa ✦
        </div>

        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-red-wine leading-[1.1] mb-6">
          Você merece uma festa
          <span class="relative inline-block">
            <span class="relative z-10">única</span>
            <span class="absolute bottom-1 left-0 w-full h-3 bg-blush/60 -z-0"></span>
          </span>
          como você
        </h1>

        <p class="text-base sm:text-lg text-red-wine/80 max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed">
          Aqui cuidamos de cada detalhe da sua festa, tudo pensado com cuidado e carinho para sempre combinar perfeitamente com o que mais desejar!
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
          <a href="#produtos" class="btn-brutal btn-brutal-primary text-base px-8 py-3">
            Ver Produtos
          </a>
          <a href="https://wa.me/5554981206756" target="_blank" rel="noopener noreferrer" class="btn-brutal btn-brutal-secondary text-base px-8 py-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Fale Conosco
          </a>
        </div>
      </div>

      <!-- Decorative cards -->
      <div class="flex-1 max-w-md w-full flex flex-col items-center">
        <!-- "O que voce vai encontrar" text -->
        <div class="mb-8 text-center bg-red-wine text-oat-milk px-6 py-3 border-2 border-red-wine shadow-brutal transform rotate-1">
          <span class="font-serif text-xl sm:text-2xl font-bold leading-tight">
            O que você vai encontrar por aqui!
          </span>
        </div>

        <!-- Floating category cards -->
        <div class="grid grid-cols-2 gap-4 w-full">
          <div class="bg-oat-milk border-2 border-red-wine shadow-brutal p-4 text-center transform -rotate-2 hover:rotate-0 transition-transform">
            <span class="text-2xl mb-1 block">🎂</span>
            <span class="font-serif font-bold text-sm">Topper de Bolo</span>
          </div>
          <div class="bg-oat-milk border-2 border-red-wine shadow-brutal p-4 text-center transform rotate-2 hover:rotate-0 transition-transform mt-6">
            <span class="text-2xl mb-1 block">🎁</span>
            <span class="font-serif font-bold text-sm">Lembrancinhas</span>
          </div>
          <div class="bg-oat-milk border-2 border-red-wine shadow-brutal p-4 text-center transform rotate-3 hover:rotate-0 transition-transform -mt-2">
            <span class="text-2xl mb-1 block">🧁</span>
            <span class="font-serif font-bold text-sm">Forminhas</span>
          </div>
          <div class="bg-oat-milk border-2 border-red-wine shadow-brutal p-4 text-center transform -rotate-1 hover:rotate-0 transition-transform mt-4">
            <span class="text-2xl mb-1 block">✨</span>
            <span class="font-serif font-bold text-sm">Decorações</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Checkerboard bottom border -->
  <div class="checkerboard-sm h-10 sm:h-14"></div>
</section>
