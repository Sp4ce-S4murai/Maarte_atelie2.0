      <!-- Coluna 3: Informações de contato -->
      <div>
        <h4 class="font-serif text-lg font-bold mb-4">Contato</h4>
        <ul class="space-y-2 text-sm">
          <!-- Telefone / WhatsApp -->
          <li class="flex items-center gap-2 opacity-80">
            <span>📱</span>
            <span>54 98120-6756</span>
          </li>
          <!-- E-mail de contato -->
          <li class="flex items-center gap-2 opacity-80">
            <span>📧</span>
            <span>contato@maarteatelie.com</span>
          </li>
          <!-- Localização -->
          <li class="flex items-center gap-2 opacity-80">
            <span>📍</span>
            <span>Canela, RS</span>
