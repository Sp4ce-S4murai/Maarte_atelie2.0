            </svg>
          </a>
          <!-- Botão Instagram - substitua o @ pelo seu perfil -->
          <a
            href="https://www.instagram.com/maarteateliee"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-oat-milk text-red-wine border-2 border-oat-milk flex items-center justify-center shadow-[2px_2px_0px_#F2AFBC] hover:shadow-none hover:translate-x-0.5 hover:translate-y-0.5 transition-all"
            aria-label="Instagram"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
