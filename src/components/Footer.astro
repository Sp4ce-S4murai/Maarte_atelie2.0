      </div>

      <!-- Coluna 2: Links de navegação rápida -->
      <div>
        <h4 class="font-serif text-lg font-bold mb-4">Links Rápidos</h4>
        <ul class="space-y-2 text-sm">
          <!-- Links internos da página - âncoras para seções -->
          <li><a href="#produtos" class="opacity-80 hover:opacity-100 hover:underline transition-opacity">Nossos Produtos</a></li>
          <li><a href="#sobre" class="opacity-80 hover:opacity-100 hover:underline transition-opacity">Sobre Nós</a></li>
